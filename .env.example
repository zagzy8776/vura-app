# Frontend (Vite). Copy to .env and set values.
# For production (Vercel), set these in Project → Settings → Environment Variables.

# Backend API base URL. Must be your backend (vura-app on Render).
# If you see 404 on /api/admin/check, your build was made with the wrong URL — set this in Vercel and redeploy.
VITE_API_URL=https://vura-app.onrender.com
