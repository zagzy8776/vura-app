# ===========================================
# VURA BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# ===========================================
# Copy this file to .env and fill in your values!

# Security - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=YOUR_JWT_SECRET_HERE
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# ===========================================
# DATABASE - PostgreSQL
# ===========================================
# Example: postgresql://postgres:password@localhost:5432/vura
DATABASE_URL="postgresql://postgres:password@localhost:5432/vura"

# ===========================================
# PAYMENT PROVIDERS
# ===========================================

# Paystack - Sign up at https://paystack.com
PAYSTACK_SECRET_KEY=sk_live_YOUR_KEY_HERE
PAYSTACK_PUBLIC_KEY=pk_live_YOUR_KEY_HERE
PAYSTACK_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Monnify - Sign up at https://monnify.com
MONNIFY_API_KEY=YOUR_MONNIFY_API_KEY
MONNIFY_CONTRACT_CODE=MKPY_XXXXXXXXXX
MONNIFY_BASE_URL=https://api.monnify.com

# Yellow Card (Crypto) - Sign up at https://yellowcard.io
YELLOWCARD_API_KEY=YOUR_YELLOWCARD_KEY
YELLOWCARD_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# IvoryPay (Crypto-to-fiat rails) - https://ivorypay.io
# Auth header: Authorization: <IVORYPAY_SECRET_KEY> (no Bearer prefix)
IVORYPAY_SECRET_KEY=sk_live_YOUR_KEY_HERE
# Webhook signature secret (set in IvoryPay dashboard)
IVORYPAY_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ===========================================
# KYC - BVN (Prembly only)
# ===========================================
# Get API key: Prembly dashboard → Integrations → API Library → API Keys (Private Live Key).
PREMBLY_API_KEY=YOUR_PREMBLY_API_KEY
# Required for BVN. Get App ID: Prembly dashboard → Integrations → API Library → Applications → copy App ID.
PREMBLY_APP_ID=your_prembly_app_id

# Prembly SDK (optional) – for full identity verification widget. From SDK setup: Config ID = PREMBLY_WIDGET_ID, Widget Key = PREMBLY_WIDGET_KEY.
# PREMBLY_WIDGET_ID=your_config_id
# PREMBLY_WIDGET_KEY=wdgt_xxxxxxxx

# ===========================================
# APPLICATION CONFIG
# ===========================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ===========================================
# BILLS PROVIDERS (Airtime, Data, Electricity)
# ===========================================
# Nellobyte (ClubKonnect) - Primary when set. Get UserID & APIKey from https://www.clubkonnect.com/
NELLOBYTE_USERID=YOUR_NELLOBYTE_USERID
NELLOBYTE_API_KEY=YOUR_NELLOBYTE_API_KEY
# Peyflex - Fallback when Nellobyte not set
PEYFLEX_API_TOKEN=YOUR_PEYFLEX_API_TOKEN_HERE

# ===========================================
# ADMIN
# ===========================================
ADMIN_SECRET=YOUR_ADMIN_SECRET_HERE

# ===========================================
# OPTIONAL
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
JWT_EXPIRES_IN=24h
SESSION_TIMEOUT_MINUTES=15
